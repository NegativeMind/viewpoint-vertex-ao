# .gitignore for a UPM package repository root.
# UnityProject~/ has its own .gitignore for Unity project-specific files.

# -----------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.DotSettings.user

# JetBrains Rider
.idea/
*.sln.iml

# Consulo
.consulo/

# -----------------------------------------------------------------------
# C# build artifacts
# -----------------------------------------------------------------------

# Auto-generated project files (Unity / Rider / VS Code)
*.csproj
*.sln
*.slnx
*.unityproj
ExportedObj/

# Debug symbols and intermediate files
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta
*.tmp

# -----------------------------------------------------------------------
# Unity
# -----------------------------------------------------------------------

# Crash / log
sysinfo.txt
mono_crash.*
*.log

# Blender source files
*.blend1
*.blend1.meta

# Gradle (Android)
.gradle/

# -----------------------------------------------------------------------
# Package distribution
# -----------------------------------------------------------------------

# npm
node_modules/

# Meta files generated at the package root by the development Unity project.
# Root-level .meta files are not part of the distributed package.
# Meta files inside Runtime/ and Editor/ are committed for GUID stability.
/*.meta
